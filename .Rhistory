group_by(.data[[var1]]) %>%
rstatix::anova_test(.data[[measure_col]] ~ .data[[var2]])
# Générer la formule dynamiquement
formule <- as.formula(paste(measure_col, "~", var2))
# Grouper par var1 et passer la formule à anova_test
